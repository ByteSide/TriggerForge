# TriggerForge - Security Configuration
# HTTP Basic Authentication + HTTPS Redirect

# Force HTTPS
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# MIME Types for PWA support
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
    AddType image/png .png
    AddType image/svg+xml .svg
</IfModule>

# Exclude PWA files from authentication
# Browsers need access to manifest and icons for PWA installation
<FilesMatch "\.(webmanifest|png|svg|ico)$">
    # Apache 2.4+
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    # Apache 2.2 fallback
    <IfModule !mod_authz_core.c>
        Satisfy Any
        Allow from all
    </IfModule>
</FilesMatch>

# HTTP Basic Authentication
# IMPORTANT: Update the path below to your server's absolute path!
AuthType Basic
AuthName "TriggerForge - Restricted Area"
AuthUserFile /path/to/your/triggerforge/.htpasswd

# Let Let's Encrypt / certbot HTTP-01 challenges through Basic Auth. If
# TriggerForge is deployed at the site root, this is required so automated
# cert renewal (via .well-known/acme-challenge/) can succeed.
SetEnvIf Request_URI "\.well-known/acme-challenge/" allow_acme
<IfModule mod_authz_core.c>
    <RequireAny>
        Require env allow_acme
        Require valid-user
    </RequireAny>
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Allow from env=allow_acme
    Satisfy Any
    Require valid-user
</IfModule>

# Protect config, docs, and sensitive files from direct access.
# Also blocks common editor/backup leftovers (~, .bak, .swp, .orig) so a
# forgotten config.php.bak can't be fetched over HTTP.
<FilesMatch "(^\.|config\.php$|\.htpasswd$|composer\.(json|lock)$|package(-lock)?\.json$|\.md$|~$|\.(bak|swp|swo|orig|old|tmp)$)">
    # Apache 2.4+
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    # Apache 2.2 fallback
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to anything inside a VCS or OS metadata directory. FilesMatch
# above only catches basenames, so e.g. .git/config (basename "config") slips
# through — RedirectMatch returns 404 for any path containing these segments.
RedirectMatch 404 (^|/)\.(git|svn|hg|bzr|DS_Store)(/|$)

# Additional security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    # X-XSS-Protection is deprecated — Chrome removed its XSS auditor, and
    # `1; mode=block` had known bypass/side-channel issues in older engines.
    # We rely on CSP (below) instead and explicitly disable the legacy filter.
    Header set X-XSS-Protection "0"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
    # CSP: self + required CDN/Google favicon. Adjust if you add external assets.
    Header set Content-Security-Policy "default-src 'self'; img-src 'self' data: https://www.google.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
</IfModule>

